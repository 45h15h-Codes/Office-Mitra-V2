# Copy this file to .env and fill in your real values
# App connection — non-superuser role, FORCE RLS applies at runtime
DATABASE_URL=postgresql://APP_USER:APP_PASSWORD@localhost:5432/officemitra
# Superuser — used by drizzle-kit migrate only (not used by the app pool)
DATABASE_SUPERUSER_URL=postgresql://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/officemitra
# Session cookie signing secret — min 32 chars random string
SESSION_SECRET=your-min-32-char-random-secret-here
